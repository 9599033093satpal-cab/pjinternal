# Aether OCR - Environment Variables Template
# Copy this file to .env and fill in your real values
# DO NOT commit .env to Git

# ── OpenAI ──────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Azure Document Intelligence ──────────────────────
AZURE_DI_ENDPOINT=https://YOUR_RESOURCE_NAME.cognitiveservices.azure.com/
AZURE_DI_KEY=your_azure_document_intelligence_key_here

# ── Optional: Gemini (Google AI) ────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Flask ────────────────────────────────────────────
FLASK_SECRET_KEY=change_this_to_a_random_secret_key
